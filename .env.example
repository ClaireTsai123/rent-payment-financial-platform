# Local Docker Compose defaults. Copy to `.env` and change values as needed.
# These values are for local development only; do not use them as production secrets.

POSTGRES_DB=rent_payment
POSTGRES_USER=rent_payment
POSTGRES_PASSWORD=rent_payment_dev_password
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=5173

SPRING_PROFILES_ACTIVE=local
MOCK_PROVIDER_WEBHOOK_SECRET=local-mock-webhook-secret

OUTBOX_PUBLISHER_BATCH_SIZE=100
OUTBOX_PUBLISHER_MAX_ATTEMPTS=3
OUTBOX_PUBLISHER_RETRY_DELAY=PT1M
OUTBOX_PUBLISHER_FIXED_DELAY=PT5S
OUTBOX_PUBLISHER_SCHEDULER_ENABLED=true
RECONCILIATION_SETTLEMENT_CHUNK_SIZE=50

# Runtime API target used by the containerized frontend Nginx proxy.
FRONTEND_BACKEND_ORIGIN=http://backend:8080
